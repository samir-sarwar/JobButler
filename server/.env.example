# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/jobbutler

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=7d

# LLM Provider (Groq-hosted GPT-OSS-120B)
LLM_API_KEY=your-groq-api-key-from-console.groq.com
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-120b

# PDF Compilation
# Options: "node-latex" (default, requires local TeX) or "docker" (uses sidecar container)
PDF_BACKEND=node-latex
# Path to pdflatex binary (only needed for node-latex backend)
# macOS with MacTeX: /Library/TeX/texbin/pdflatex
# Linux with TeX Live: pdflatex (on PATH)
# Leave blank to use system PATH default
PDFLATEX_CMD=
# Required if PDF_BACKEND=docker
DOCKER_LATEX_URL=http://localhost:3002/compile
# Temp directory for LaTeX compilation
PDF_TMP_DIR=/tmp/jobbutler
# Optional: persistent PDF storage directory (leave empty to skip saving)
PDF_STORAGE_PATH=

# CORS
CLIENT_ORIGIN=http://localhost:5174
